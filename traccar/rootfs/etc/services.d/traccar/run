#!/command/with-contenv bashio
declare -a options
declare status

bashio::log.info "Starting Traccar server..."

# Memory settings
options+=(-Xms256m)
options+=(-Xmx512m)

# Prefer IPv4, because of Hassio general issues with IPv6
options+=("-Djava.net.preferIPv4Stack=true")

# Run the JAR
options+=(-jar tracker-server.jar)

# Configuration file
options+=(/config/traccar.xml)

# Run the Traccar daemon
cd /opt/traccar || bashio::exit.nok "Failed to switch to Traccar directory"

bashio::log.info "Working dir: $(pwd)"
bashio::log.info "Listing /opt/traccar:"
ls -lah /opt/traccar || true
bashio::log.info "Listing /opt/traccar/logs:"
ls -lah /opt/traccar/logs || true
bashio::log.info "Listing /config:"
ls -lah /config || true

java "${options[@]}" > /tmp/traccar-stdout.log 2> /tmp/traccar-stderr.log
status=$?

bashio::log.error "Traccar exited with status ${status}"
bashio::log.error "==== STDOUT ===="
cat /tmp/traccar-stdout.log || true
bashio::log.error "==== STDERR ===="
cat /tmp/traccar-stderr.log || true

for logfile in \
  /opt/traccar/logs/tracker-server.log \
  /opt/traccar/logs/traccar.log \
  /opt/traccar/logs/wrapper.log \
  /opt/traccar/logs/debug.log
do
  if [ -f "${logfile}" ]; then
    bashio::log.error "==== Contents of ${logfile} ===="
    cat "${logfile}" || true
  fi
done

exit "${status}"
